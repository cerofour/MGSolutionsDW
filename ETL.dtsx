    <DTS:Executable
      DTS:refId="Package\Dim-Tiempo"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Tarea Ejecutar SQL"
      DTS:DTSID="{08E88EAB-3357-4122-B67E-4980689A212D}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Dim-Tiempo"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{16925508-E452-4B15-BC6C-8B38C37302E3}"
          SQLTask:SqlStatementSource="&#xA;if not exists (select * from sysobjects where name='DimTiempo' and xtype='U')&#xA;&#xA;&#xA;CREATE TABLE dbo.DimTiempo (&#xA;    TiempoKey INT PRIMARY KEY,      -- formato YYYYMMDD, smart key&#xA;    Fecha DATE NOT NULL,&#xA;    Anio INT,&#xA;    Trimestre INT,&#xA;    Mes INT,&#xA;    NombreMes VARCHAR(20),&#xA;    Semana INT,&#xA;    Dia INT,&#xA;    NombreDia VARCHAR(20),&#xA;    EsFinSemana BIT,&#xA;    EsDiaFestivo BIT&#xA;);&#xA;&#xA;DECLARE @FechaInicio DATE = '2020-01-01';&#xA;DECLARE @FechaFin DATE = '2030-12-31';&#xA;&#xA;;WITH Fechas AS (&#xA;    SELECT @FechaInicio AS Fecha&#xA;    UNION ALL&#xA;    SELECT DATEADD(DAY, 1, Fecha)&#xA;    FROM Fechas&#xA;    WHERE Fecha &lt; @FechaFin&#xA;)&#xA;INSERT INTO dbo.DimTiempo&#xA;SELECT&#xA;    CONVERT(INT, FORMAT(Fecha, 'yyyyMMdd')) AS TiempoKey,&#xA;    Fecha,&#xA;    YEAR(Fecha) AS Anio,&#xA;    DATEPART(QUARTER, Fecha) AS Trimestre,&#xA;    MONTH(Fecha) AS Mes,&#xA;    CASE MONTH(Fecha)&#xA;        WHEN 1 THEN 'Enero' WHEN 2 THEN 'Febrero' WHEN 3 THEN 'Marzo'&#xA;        WHEN 4 THEN 'Abril' WHEN 5 THEN 'Mayo' WHEN 6 THEN 'Junio'&#xA;        WHEN 7 THEN 'Julio' WHEN 8 THEN 'Agosto' WHEN 9 THEN 'Septiembre'&#xA;        WHEN 10 THEN 'Octubre' WHEN 11 THEN 'Noviembre' WHEN 12 THEN 'Diciembre'&#xA;    END AS NombreMes,&#xA;    DATEPART(WEEK, Fecha) AS Semana,&#xA;    DAY(Fecha) AS Dia,&#xA;    CASE DATEPART(WEEKDAY, Fecha)&#xA;        WHEN 1 THEN 'Domingo' WHEN 2 THEN 'Lunes' WHEN 3 THEN 'Martes'&#xA;        WHEN 4 THEN 'Miércoles' WHEN 5 THEN 'Jueves' WHEN 6 THEN 'Viernes'&#xA;        WHEN 7 THEN 'Sábado'&#xA;    END AS NombreDia,&#xA;    CASE WHEN DATEPART(WEEKDAY, Fecha) IN (1,7) THEN 1 ELSE 0 END AS EsFinSemana,&#xA;    0 AS EsDiaFestivo -- se actualiza en el paso 2&#xA;FROM Fechas&#xA;OPTION (MAXRECURSION 0);&#xA;GO&#xA;&#xA;&#xA;if not exists (select * from sysobjects where name='festivos' and xtype='U')&#xA;CREATE TABLE dbo.Festivos (Fecha DATE PRIMARY KEY, Nombre VARCHAR(64));&#xA;&#xA;-- Asegúrate de que la tabla acepte la longitud de los nombres comerciales&#xA;INSERT INTO dbo.Festivos VALUES&#xA;-- Feriados Base y fijos anuales (Ejemplo 2026 proporcionado)&#xA;('2026-01-01', 'Año Nuevo'),&#xA;('2026-05-01', 'Día del Trabajo'),&#xA;('2026-07-28', 'Fiestas Patrias'),&#xA;('2026-07-29', 'Fiestas Patrias'),&#xA;('2026-12-25', 'Navidad'),&#xA;&#xA;-- ========================================================&#xA;-- HISTÓRICO DE CAMPAÑAS COMERCIALES Y CYBER (2022 - 2025)&#xA;-- ========================================================&#xA;&#xA;-- --- AÑO 2022 ---&#xA;-- Cyber Days &amp; Cyber Wow 2022&#xA;('2022-03-28', 'Cyber Days I 2022'), ('2022-03-29', 'Cyber Days I 2022'), ('2022-03-30', 'Cyber Days I 2022'),&#xA;('2022-04-18', 'Cyber Wow I 2022'), ('2022-04-19', 'Cyber Wow I 2022'), ('2022-04-20', 'Cyber Wow I 2022'), ('2022-04-21', 'Cyber Wow I 2022'), ('2022-04-22', 'Cyber Wow I 2022'),&#xA;-- Se eliminaron duplicados de Cyber Days II (04, 05 y 06 de julio) priorizando Cyber Wow II&#xA;('2022-07-04', 'Cyber Wow II 2022'), ('2022-07-05', 'Cyber Wow II 2022'), ('2022-07-06', 'Cyber Wow II 2022'), ('2022-07-07', 'Cyber Wow II 2022'), ('2022-07-08', 'Cyber Wow II 2022'),&#xA;('2022-10-24', 'Cyber Wow III 2022'), ('2022-10-25', 'Cyber Wow III 2022'), ('2022-10-26', 'Cyber Wow III 2022'), ('2022-10-27', 'Cyber Wow III 2022'), ('2022-10-28', 'Cyber Wow III 2022'),&#xA;('2022-11-14', 'Cyber Days III 2022'), ('2022-11-15', 'Cyber Days III 2022'), ('2022-11-16', 'Cyber Days III 2022'),&#xA;-- Hitos comerciales de tecnología 2022&#xA;('2022-05-08', 'Día de la Madre 2022'),&#xA;('2022-06-19', 'Día del Padre 2022'),&#xA;('2022-11-25', 'Black Friday 2022'),&#xA;&#xA;-- --- AÑO 2023 ---&#xA;-- Cyber Days &amp; Cyber Wow 2023&#xA;('2023-03-27', 'Cyber Days I 2023'), ('2023-03-28', 'Cyber Days I 2023'), ('2023-03-29', 'Cyber Days I 2023'),&#xA;('2023-04-17', 'Cyber Wow I 2023'), ('2023-04-18', 'Cyber Wow I 2023'), ('2023-04-19', 'Cyber Wow I 2023'), ('2023-04-20', 'Cyber Wow I 2023'), ('2023-04-21', 'Cyber Wow I 2023'),&#xA;('2023-07-03', 'Cyber Wow II 2023'), ('2023-07-04', 'Cyber Wow II 2023'), ('2023-07-05', 'Cyber Wow II 2023'), ('2023-07-06', 'Cyber Wow II 2023'), ('2023-07-07', 'Cyber Wow II 2023'),&#xA;('2023-07-17', 'Cyber Days II 2023'), ('2023-07-18', 'Cyber Days II 2023'), ('2023-07-19', 'Cyber Days II 2023'),&#xA;('2023-10-23', 'Cyber Wow III 2023'), ('2023-10-24', 'Cyber Wow III 2023'), ('2023-10-25', 'Cyber Wow III 2023'), ('2023-10-26', 'Cyber Wow III 2023'), ('2023-10-27', 'Cyber Wow III 2023'),&#xA;('2023-11-13', 'Cyber Days III 2023'), ('2023-11-14', 'Cyber Days III 2023'), ('2023-11-15', 'Cyber Days III 2023'),&#xA;-- Hitos comerciales de tecnología 2023&#xA;('2023-05-14', 'Día de la Madre 2023'),&#xA;('2023-06-18', 'Día del Padre 2023'),&#xA;('2023-11-24', 'Black Friday 2023'),&#xA;&#xA;-- --- AÑO 2024 ---&#xA;-- Cyber Days &amp; Cyber Wow 2024&#xA;('2024-03-18', 'Cyber Days I 2024'), ('2024-03-19', 'Cyber Days I 2024'), ('2024-03-20', 'Cyber Days I 2024'),&#xA;('2024-04-15', 'Cyber Wow I 2024'), ('2024-04-16', 'Cyber Wow I 2024'), ('2024-04-17', 'Cyber Wow I 2024'), ('2024-04-18', 'Cyber Wow I 2024'), ('2024-04-19', 'Cyber Wow I 2024'),&#xA;('2024-07-15', 'Cyber Wow II 2024'), ('2024-07-16', 'Cyber Wow II 2024'), ('2024-07-17', 'Cyber Wow II 2024'), ('2024-07-18', 'Cyber Wow II 2024'), ('2024-07-19', 'Cyber Wow II 2024'),&#xA;('2024-07-22', 'Cyber Days II 2024'), ('2024-07-23', 'Cyber Days II 2024'), ('2024-07-24', 'Cyber Days II 2024'),&#xA;('2024-11-04', 'Cyber Wow III 2024'), ('2024-11-05', 'Cyber Wow III 2024'), ('2024-11-06', 'Cyber Wow III 2024'), ('2024-11-07', 'Cyber Wow III 2024'), ('2024-11-08', 'Cyber Wow III 2024'),&#xA;('2024-11-11', 'Cyber Days III 2024'), ('2024-11-12', 'Cyber Days III 2024'), ('2024-11-13', 'Cyber Days III 2024'),&#xA;-- Hitos comerciales de tecnología 2024&#xA;('2024-05-12', 'Día de la Madre 2024'),&#xA;('2024-06-16', 'Día del Padre 2024'),&#xA;('2024-11-29', 'Black Friday 2024'),&#xA;&#xA;-- --- AÑO 2025 ---&#xA;-- Cyber Days &amp; Cyber Wow 2025&#xA;('2025-03-24', 'Cyber Days I 2025'), ('2025-03-25', 'Cyber Days I 2025'), ('2025-03-26', 'Cyber Days I 2025'),&#xA;('2025-04-21', 'Cyber Wow I 2025'), ('2025-04-22', 'Cyber Wow I 2025'), ('2025-04-23', 'Cyber Wow I 2025'), ('2025-04-24', 'Cyber Wow I 2025'), ('2025-04-25', 'Cyber Wow I 2025'),&#xA;('2025-07-07', 'Cyber Wow II 2025'), ('2025-07-08', 'Cyber Wow II 2025'), ('2025-07-09', 'Cyber Wow II 2025'), ('2025-07-10', 'Cyber Wow II 2025'), ('2025-07-11', 'Cyber Wow II 2025'),&#xA;('2025-07-21', 'Cyber Days II 2025'), ('2025-07-22', 'Cyber Days II 2025'), ('2025-07-23', 'Cyber Days II 2025'),&#xA;('2025-10-27', 'Cyber Wow III 2025'), ('2025-10-28', 'Cyber Wow III 2025'), ('2025-10-29', 'Cyber Wow III 2025'), ('2025-10-30', 'Cyber Wow III 2025'), ('2025-10-31', 'Cyber Wow III 2025'),&#xA;('2025-11-17', 'Cyber Days III 2025'), ('2025-11-18', 'Cyber Days III 2025'), ('2025-11-19', 'Cyber Days III 2025'),&#xA;-- Hitos comerciales de tecnología 2025&#xA;('2025-05-11', 'Día de la Madre 2025'),&#xA;('2025-06-15', 'Día del Padre 2025'),&#xA;('2025-11-28', 'Black Friday 2025');&#xA;&#xA;UPDATE d&#xA;SET EsDiaFestivo = 1&#xA;FROM dbo.DimTiempo d&#xA;INNER JOIN dbo.Festivos f ON d.Fecha = f.Fecha;&#xA;GO" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
