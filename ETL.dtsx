                  expressionType="Notify"
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT        dbo.Empleado.id_empleado AS codigoUsuario, dbo.Usuario.id_usuario AS codigoEmpleado, dbo.Empleado.nombre, dbo.Empleado.apellidoPaterno, dbo.Empleado.apellidoMaterno, 
                         dbo.Usuario.id_tipoUsuario AS codigoTipoUsuario, dbo.Empleado.email
FROM            dbo.Empleado INNER JOIN
                         dbo.Usuario ON dbo.Empleado.id_empleado = dbo.Usuario.id_empleado</property>
                <property
                  dataType="System.Int32"
