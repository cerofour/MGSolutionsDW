            <component
              refId="Package\FactInventario\FactInventario"
              componentClassID="Microsoft.OLEDBSource"
              contactInfo="Origen de OLE DB;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; Todos los derechos reservados; http://www.microsoft.com/sql/support;7"
              description="Origen de OLE DB"
              name="FactInventario"
              usesDispositions="true"
              version="7">
              <properties>
                <property
                  dataType="System.Int32"
                  description="Número de segundos antes de que se agote el tiempo de espera de un comando. Un valor de 0 indica un tiempo de espera infinito."
                  name="CommandTimeout">0</property>
                <property
                  dataType="System.String"
                  description="Especifica el nombre del objeto de base de datos usado para abrir un conjunto de filas."
                  name="OpenRowset"></property>
                <property
                  dataType="System.String"
                  description="Especifica la variable que contiene el nombre del objeto de base de datos usado para abrir un conjunto de filas."
                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="Comando SQL para ejecutar."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">WITH Movimientos AS
(
    -- COMPRAS
    SELECT
        CAST(c.fechaEmision AS DATE) AS fecha,
        dc.id_item,
        dc.cantidad AS movimientoCantidad,
        dc.costo AS costoCompra,
        NULL AS fechaVenta,
        0 AS tipoMovimiento   -- 0 = compra, se procesa primero
    FROM Compra c
    INNER JOIN DetalleCompra dc
        ON c.id_compra = dc.id_compra

    UNION ALL

    -- VENTAS
    SELECT
        CAST(v.fechaEmision AS DATE) AS fecha,
        dv.id_item,
        -dv.cantidad AS movimientoCantidad,
        NULL AS costoCompra,
        CAST(v.fechaEmision AS DATE) AS fechaVenta,
        1 AS tipoMovimiento   -- 1 = venta, se procesa después
    FROM Venta v
    INNER JOIN DetalleVentaGeneral dv
        ON v.id_venta = dv.id_venta
    WHERE dv.id_item IS NOT NULL
),

Calculos AS
(
    SELECT
        fecha,
        id_item,
        movimientoCantidad,
        costoCompra,
        fechaVenta,

        -- STOCK ACUMULADO
        SUM(movimientoCantidad)
        OVER(
            PARTITION BY id_item
            ORDER BY fecha, tipoMovimiento   -- 👈 desempate: compras antes que ventas
            ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW
        ) AS stockActual,

        -- ULTIMA VENTA
        MAX(fechaVenta)
        OVER(
            PARTITION BY id_item
            ORDER BY fecha, tipoMovimiento
            ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW
        ) AS fechaUltimaVenta,

        -- ÚLTIMO COSTO DE COMPRA REAL
        MAX(costoCompra)
        OVER(
            PARTITION BY id_item
            ORDER BY fecha, tipoMovimiento
            ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW
        ) AS ultimoCostoCompra

    FROM Movimientos
)

SELECT
    fecha,
    id_item,
    MAX(stockActual) AS stockActual,
    ISNULL(
        DATEDIFF(DAY, MAX(fechaUltimaVenta), fecha),
        -1
    ) AS diasSinVenta,
    MAX(fechaUltimaVenta) AS fechaUltimaVenta,
    MAX(stockActual) * MAX(ultimoCostoCompra) AS valorInventario
FROM Calculos

GROUP BY
    fecha,
    id_item
ORDER BY
    fecha,
    id_item;</property>
                <property
